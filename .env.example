# ==========================================
# PostgreSQL Configuration
# ==========================================
POSTGRES_USER=fintech_user
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_DEV_ONLY
POSTGRES_DB=postgres

# ==========================================
# JWT Configuration (shared across all services)
# Generate a strong secret: openssl rand -base64 48
# ==========================================
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRATION=3600000

# ==========================================
# Database URLs (note: hostname is "postgres", not "localhost")
# Each service connects to its own logical database
# ==========================================
DB_AUTH_URL=jdbc:postgresql://postgres:5432/fintech_auth
DB_USER_URL=jdbc:postgresql://postgres:5432/fintech_users
DB_TRANSACTION_URL=jdbc:postgresql://postgres:5432/fintech_transactions
DB_USERNAME=fintech_user
DB_PASSWORD=CHANGE_ME_LOCAL_DEV_ONLY
