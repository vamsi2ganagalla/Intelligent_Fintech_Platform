# COPY THIS FILE TO secret.yaml AND FILL IN REAL VALUES
# secret.yaml is gitignored — do not commit real secrets
#
# For local dev, the values in 10-config/secret.yaml mirror those in
# .env (same Postgres password, same JWT secret) so the K8s and
# docker-compose stacks are interchangeable for testing.

apiVersion: v1
kind: Secret
metadata:
  name: fintech-secrets
  namespace: default
  labels:
    app.kubernetes.io/part-of: fintech-platform
type: Opaque
stringData:
  POSTGRES_PASSWORD: CHANGE_ME_LOCAL_DEV_ONLY
  DB_PASSWORD: CHANGE_ME_LOCAL_DEV_ONLY
  JWT_SECRET: CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48
